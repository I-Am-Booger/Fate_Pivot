require("globals")
require("grid_draw")
require("grid_table")

function love.load()
    --[[ START SCREEN STUFF, SETTING THE TITLE, RESOLUTION, 
         GAMESTATE BETWEEN TITLE SCREEN AND BACKGROUND mUSIC ]]
    love.window.setMode(1920, 1080)
    love.window.setTitle("Fate & Pivot")
    
    -- title stuff 
    gameState = "title"
    showEnter = true

    --start page song 
    backgroundMusic = love.audio.newSource("music/IntroSong.mp3", "stream")
    --looping the song
    backgroundMusic:setLooping(true)
    love.audio.play(backgroundMusic)
    -- End o screen stuff etc

---------------------------------------------------------------------------------
    bigFont = love.graphics.newFont(48)

    score = 0 
    timer = 2
    level = 0 














--blinking timer 
blinkTimer = 0
-- end of blinking timer 

-- emd of title stuff
building_the_grid()

    -- need to work on this 
    playerBlock = {
        col1 = 1, 
        row  = 1,
        color = "white"
    }
    -- The end of work on this
end


function love.update(dt)
    
    -- working on blinking timer 
    blinkTimer = blinkTimer + dt    

    if blinkTimer >= 2 then 
        showEnter = not showEnter
        blinkTimer = 0
    end
    -- end of working on blinking timer 


    if gameState == "title" then 
        if love.keyboard.isDown("return") then 
            gameState = "play" 
        end
    end 
end 





















function love.draw()
    
    if gameState == "title" then 
        love.graphics.setFont(bigFont)
        love.graphics.print("Fate & Pivot", 800, 325 )
        if showEnter == true then 
            love.graphics.print("Press ENTER", 800, 375)
        end
    end 

    if gameState == "play" then 
    
        
        grid()
        
        
        love.graphics.line(1500, 1500, 1500, 0  )     
        love.graphics.setFont(bigFont)
        
        love.graphics.print("Lvl: " .. level, 1600, 100)
        love.graphics.print("Timer: " .. timer, 1600, 180)
        love.graphics.print("Scores: " .. score, 1600, 260)
    end 
        
    
end 